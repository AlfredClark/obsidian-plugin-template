{
  "name": "obsidian-plugin-template",
  "version": "0.6.0",
  "description": "A Vite based Obsidian plugin development template",
  "homepage": "https://github.com/AlfredClark/obsidian-plugin-template",
  "author": {
    "name": "Alfred Clark",
    "email": "alfredclark@163.com",
    "url": "https://github.com/AlfredClark"
  },
  "license": "GPL-3.0",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit --skipLibCheck && vite build --mode production",
    "lint": "eslint src/",
    "check": "prettier --check '**/*.ts'",
    "format": "prettier --write '**/*.ts'",
    "dist-link": "node dist-link.ts",
    "clean": "rimraf dist main.js main.js.map",
    "clean:dist": "rimraf dist/*",
    "clean:deep": "rimraf dist main.js main.js.map node_modules",
    "version": "node version-bump.ts && git add manifest.json versions.json",
    "i18n:compile": "paraglide-js compile --project ./src/i18n/project.inlang --outdir ./src/i18n/paraglide",
    "machine-translate": "inlang machine translate --project src/i18n/project.inlang"
  },
  "dependencies": {
    "obsidian": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sveltejs/vite-plugin-svelte": "^7.1.4",
    "@types/node": "^25.9.4",
    "esbuild": "^0.28.1",
    "esbuild-svelte": "^0.9.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "rimraf": "^6.1.3",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vite-plugin-eslint2": "^5.3.0",
    "@inlang/paraglide-js": "^2.20.2",
    "@inlang/cli": "^3.1.15"
  }
}
